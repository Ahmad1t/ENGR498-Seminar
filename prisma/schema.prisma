generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Itinerary {
  id             String   @id @default(cuid())
  userId         String
  origin         String
  destination    String
  departureDate  DateTime
  offerId        String?
  totalAmount    Float?
  currency       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
